# plainfare configuration
# Copy to .env and fill in your values

# ── Server ─────────────────────────────────────────────
# PLAINFARE_PORT=3141
# PLAINFARE_BASE_URL=https://plainfare.example.com

# ── Recipes directory (host path for docker-compose) ───
# PLAINFARE_RECIPES_DIR=./recipes

# ── AI provider (optional) ─────────────────────────────
# Any OpenAI-compatible API works (OpenAI, Ollama, etc.)
# PLAINFARE_AI_ENDPOINT=https://api.openai.com
# PLAINFARE_AI_API_KEY=sk-...
# PLAINFARE_AI_MODEL=gpt-4o

# ── Job queue ──────────────────────────────────────────
# PLAINFARE_JOB_CONCURRENCY=2

# ── Telegram bot (optional) ────────────────────────────
# Create a bot via @BotFather on Telegram, paste token here
# PLAINFARE_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Authentication (optional) ─────────────────────────
# Set both to require login. Unset both for open access.
# PLAINFARE_USERNAME=admin
# PLAINFARE_PASSWORD=changeme
