# mise configuration
# Copy to .env and fill in your values

# ── Server ─────────────────────────────────────────────
# MISE_PORT=3141
# MISE_BASE_URL=https://mise.example.com

# ── Recipes directory (host path for docker-compose) ───
# MISE_RECIPES_DIR=./recipes

# ── AI provider (optional) ─────────────────────────────
# Any OpenAI-compatible API works (OpenAI, Ollama, etc.)
# MISE_AI_ENDPOINT=https://api.openai.com
# MISE_AI_API_KEY=sk-...
# MISE_AI_MODEL=gpt-4o

# ── Telegram bot (optional) ────────────────────────────
# Create a bot via @BotFather on Telegram, paste token here
# MISE_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
