{
  "name": "@plainfare/web",
  "version": "0.1.0",
  "description": "Web service — Hono server + React UI",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "dev": "tsx watch src/server/index.ts",
    "dev:ui": "vite dev",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:ai": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@plainfare/core": "workspace:*",
    "@tanstack/react-query": "^5.95.2",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.1.0",
    "chokidar": "^4.0.3",
    "grammy": "^1.41.1",
    "hono": "^4.7.11",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.3",
    "vitest": "^3.0.0"
  }
}
